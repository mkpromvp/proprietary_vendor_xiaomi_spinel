service vendor.fps_hal /vendor/bin/hw/android.hardware.biometrics.fingerprint-service.odm
    interface aidl android.hardware.biometrics.fingerprint.IFingerprint/default
    class late_start
    user system
    group system drmrpc diag input uhid
    seclabel u:r:hal_fingerprint_default:s0
    capabilities SYS_NICE



on boot
    chmod 0666 /dev/xiaomi-fp
    chown system system /dev/xiaomi-fp
    chmod 0666 /dev/input/event5



on post-fs-data

    mkdir /data/vendor/fpdump
    chown system system /data/vendor/fpdump
    chmod 0700 /data/vendor/fpdump
    mkdir /mnt/vendor/persist/fingerprint 0777 system system
    mkdir /mnt/vendor/persist/fingerprint/jiiov 0777 system system
    chown system system /dev/xiaomi-fp
    chmod 0644 /dev/xiaomi-fp
    chown system system /sys/class/mi_display/disp-DSI-0/disp_param
    chmod 0777 /sys/class/mi_display/disp-DSI-0/disp_param


on property:vendor.fps_hal.restartimes=max
    stop vendor.fps_hal

on property:vendor.fp.dummy.dfs=*
     stop vendor.fps_hal
     start vendor.fps_hal